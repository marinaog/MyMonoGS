build /home/marina/PhD/RawSLAM/MyMonoGS/submodules/hist-rasterization/build/temp.linux-x86_64-cpython-312/cuda_rasterizer/rasterizer_impl.o: cuda_compile /home/marina/PhD/RawSLAM/MyMonoGS/submodules/hist-rasterization/cuda_rasterizer/rasterizer_impl.cu
build /home/marina/PhD/RawSLAM/MyMonoGS/submodules/hist-rasterization/build/temp.linux-x86_64-cpython-312/ext.o: compile /home/marina/PhD/RawSLAM/MyMonoGS/submodules/hist-rasterization/ext.cpp
